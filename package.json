{
  "name": "express-with-typescript-template",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "clean": "rm -rf dist",
    "build:cjs": "tsc --module CommonJS --outDir dist/cjs --removeComments",
    "build:esm": "tsc --module ESNext --outDir dist --removeComments",
    "build:dts": "tsc --module ESNext --outDir dist --declaration --emitDeclarationOnly",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:dts",
    "bun": "bun run --hot --watch app.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srakib17"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/srakib17"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "homepage": "https://github.com/srakib17",
  "dependencies": {
    "@auth/core": "^0.39.0",
    "@googleapis/oauth2": "^1.0.7",
    "@types/autocannon": "^7.12.7",
    "@types/bun": "^1.3.3",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "bun": "^1.2.2",
    "pkgroll": "^2.11.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tezx": "^4.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "typescript": "^5.8.3"
  }
}